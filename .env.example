# ==========================================================================
# Zahira AI Agent - Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ==========================================================================

# ----- Core -----
NODE_ENV=development
BACKEND_PORT=4000
FRONTEND_PORT=3000

# Public URL the frontend uses to reach the backend API
NEXT_PUBLIC_API_URL=http://localhost:4000

# ----- Database (PostgreSQL + pgvector) -----
POSTGRES_USER=zahira
POSTGRES_PASSWORD=zahira_dev_password
POSTGRES_DB=zahira
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://zahira:zahira_dev_password@localhost:5432/zahira?schema=public

# ----- Redis (cache + BullMQ jobs) -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ----- Auth -----
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Initial admin (created by seed)
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@zahira.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# ----- OpenAI / AI Provider -----
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# ----- SendPulse webhook -----
SENDPULSE_WEBHOOK_SECRET=change_me_webhook_secret

# ----- Lovable read-only availability functions -----
LOVABLE_AI_BASE_URL=https://umjdracnldnngufpfcak.supabase.co/functions/v1
ZAHIRA_AI_API_KEY=change_me_shared_lovable_ai_key
AVAILABILITY_LOOKUP_ENABLED=true
AVAILABILITY_TIMEOUT_MS=8000
AVAILABILITY_MAX_SLOTS=3

# ----- Misc -----
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000
