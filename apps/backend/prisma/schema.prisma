// Zahira AI Agent - Prisma schema
// PostgreSQL + pgvector. Portuguese-only WhatsApp assistant platform.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Intent {
  greeting
  pricing
  booking
  availability
  opening_hours
  support
  complaint
  menu
  general_question
  human_handoff
}

enum AiExit {
  CONTINUE
  BOOKING
  SUPPORT
  MENU
  END_SESSION
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MemoryType {
  SHORT_TERM
  LONG_TERM
}

enum SessionStatus {
  ACTIVE
  CLOSED
}

enum HandoffStatus {
  PENDING
  ASSIGNED
  RESOLVED
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  CANCELLED
}

enum EmbeddingSourceType {
  SERVICE
  KNOWLEDGE
}

enum AdminRole {
  ADMIN
  STAFF
}

// ---------------------------------------------------------------------------
// Auth
// ---------------------------------------------------------------------------

model Admin {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         AdminRole  @default(ADMIN)
  createdAt    DateTime   @default(now()) @map("created_at")

  handoffs       Handoff[]
  promptVersions PromptVersion[]

  @@map("admins")
}

// ---------------------------------------------------------------------------
// WhatsApp end-users
// ---------------------------------------------------------------------------

model User {
  id          String   @id @default(uuid())
  phone       String   @unique
  name        String?
  firstSeenAt DateTime @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  metadata    Json?

  sessions Session[]
  memories Memory[]
  bookings Booking[]
  handoffs Handoff[]

  @@index([phone])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Sessions + conversation
// ---------------------------------------------------------------------------

model Session {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  status         SessionStatus @default(ACTIVE)
  mode           String?
  messageCount   Int           @default(0) @map("message_count")
  qualifyingQuestionCount Int   @default(0) @map("qualifying_question_count")
  bookingAttemptCount     Int   @default(0) @map("booking_attempt_count")
  salesPitchCount         Int   @default(0) @map("sales_pitch_count")
  handoffReason           String? @map("handoff_reason")
  startedAt      DateTime      @default(now()) @map("started_at")
  lastActivityAt DateTime      @default(now()) @map("last_activity_at")
  closedAt       DateTime?     @map("closed_at")

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  summaries SessionSummary[]
  handoffs  Handoff[]
  bookings  Booking[]
  aiRuns    AiRun[]

  @@index([userId])
  @@index([status])
  @@index([lastActivityAt])
  @@map("sessions")
}

model SessionSummary {
  id                    String   @id @default(uuid())
  sessionId             String   @map("session_id")
  summary               String
  upToMessageId         String?  @map("up_to_message_id")
  messageCountAtSummary Int      @map("message_count_at_summary")
  createdAt             DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("session_summaries")
}

model Message {
  id         String      @id @default(uuid())
  sessionId  String      @map("session_id")
  role       MessageRole
  content    String
  intent     Intent?
  aiExit     AiExit?     @map("ai_exit")
  tokensUsed Int?        @map("tokens_used")
  createdAt  DateTime    @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("messages")
}

// ---------------------------------------------------------------------------
// Memory
// ---------------------------------------------------------------------------

model Memory {
  id              String     @id @default(uuid())
  userId          String     @map("user_id")
  type            MemoryType @default(LONG_TERM)
  content         String
  relevanceScore  Float      @default(0.5) @map("relevance_score")
  sourceSessionId String?    @map("source_session_id")
  createdAt       DateTime   @default(now()) @map("created_at")
  expiresAt       DateTime?  @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("memories")
}

// ---------------------------------------------------------------------------
// Knowledge sources (RAG)
// ---------------------------------------------------------------------------

model Service {
  id          String    @id @default(uuid())
  serviceName String    @map("service_name")
  category    String?
  description String?
  price       String?
  duration    String?
  faq         Json      @default("[]")
  keywords    String[]  @default([])
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  bookings Booking[]

  @@index([deletedAt])
  @@map("services")
}

model KnowledgeBase {
  id        String    @id @default(uuid())
  title     String
  content   String
  category  String?
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("knowledge_base")
}

/// Polymorphic vector store shared by services and knowledge_base.
/// The `embedding` column is created/altered to vector(1536) via migration SQL.
model Embedding {
  id         BigInt              @id @default(autoincrement())
  sourceType EmbeddingSourceType @map("source_type")
  sourceId   String              @map("source_id")
  chunkIndex Int                 @map("chunk_index")
  content    String
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime            @default(now()) @map("created_at")

  @@index([sourceType, sourceId])
  @@map("embeddings")
}

// ---------------------------------------------------------------------------
// Handoffs + bookings
// ---------------------------------------------------------------------------

model Handoff {
  id              String        @id @default(uuid())
  sessionId       String        @map("session_id")
  userId          String        @map("user_id")
  status          HandoffStatus @default(PENDING)
  assignedAdminId String?       @map("assigned_admin_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  resolvedAt      DateTime?     @map("resolved_at")

  session       Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAdmin Admin?  @relation(fields: [assignedAdminId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([sessionId])
  @@map("handoffs")
}

model Booking {
  id        String        @id @default(uuid())
  userId    String        @map("user_id")
  sessionId String?       @map("session_id")
  serviceId String?       @map("service_id")
  status    BookingStatus @default(REQUESTED)
  notes     String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("bookings")
}

// ---------------------------------------------------------------------------
// Prompts (versioned) + AI observability
// ---------------------------------------------------------------------------

model Prompt {
  id              String   @id @default(uuid())
  key             String   @unique
  activeVersionId String?  @unique @map("active_version_id")
  updatedAt       DateTime @updatedAt @map("updated_at")

  versions      PromptVersion[] @relation("PromptVersions")
  activeVersion PromptVersion?  @relation("ActivePromptVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)

  @@map("prompts")
}

model PromptVersion {
  id        String   @id @default(uuid())
  promptId  String   @map("prompt_id")
  version   Int
  content   String
  isActive  Boolean  @default(false) @map("is_active")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  prompt        Prompt  @relation("PromptVersions", fields: [promptId], references: [id], onDelete: Cascade)
  activeFor     Prompt? @relation("ActivePromptVersion")
  createdByAdmin Admin? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([promptId, version])
  @@index([promptId])
  @@map("prompt_versions")
}

model AiRun {
  id               String   @id @default(uuid())
  sessionId        String?  @map("session_id")
  messageId        String?  @map("message_id")
  intent           Intent?
  aiExit           AiExit?  @map("ai_exit")
  provider         String?
  model            String?
  tokensPrompt     Int?     @map("tokens_prompt")
  tokensCompletion Int?     @map("tokens_completion")
  tokensTotal      Int?     @map("tokens_total")
  retrievedDocs    Int?     @map("retrieved_docs")
  promptVersion    Int?     @map("prompt_version")
  latencyMs        Int?     @map("latency_ms")
  error            String?
  createdAt        DateTime @default(now()) @map("created_at")

  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([createdAt])
  @@map("ai_runs")
}

// ---------------------------------------------------------------------------
// Settings + analytics
// ---------------------------------------------------------------------------

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  type      String
  userId    String?  @map("user_id")
  sessionId String?  @map("session_id")
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([createdAt])
  @@map("analytics_events")
}
